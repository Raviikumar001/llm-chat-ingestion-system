{
  "name": "ollive",
  "private": true,
  "version": "1.0.0",
  "description": "Lightweight inference logging and ingestion system for an LLM chatbot",
  "scripts": {
    "dev": "pnpm --parallel --filter @ollive/api --filter @ollive/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @ollive/api db:migrate",
    "db:generate": "pnpm --filter @ollive/api db:generate",
    "db:studio": "pnpm --filter @ollive/api db:studio"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.1.0"
}
